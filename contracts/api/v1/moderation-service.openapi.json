          },
          {
            "$ref": "#/components/parameters/UserIDHeader"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKeyHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "503": {
            "$ref": "#/components/responses/Error"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/moderation/reject": {
      "post": {
        "summary": "Reject submission",
        "operationId": "moderationReject",
        "parameters": [
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          },
          {
            "$ref": "#/components/parameters/RequestIDHeader"
          },
          {
            "$ref": "#/components/parameters/UserIDHeader"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKeyHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RejectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "503": {
            "$ref": "#/components/responses/Error"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/moderation/flag": {
      "post": {
        "summary": "Flag submission",
        "operationId": "moderationFlag",
        "parameters": [
          {
            "$ref": "#/components/parameters/AuthorizationHeader"
          },
          {
            "$ref": "#/components/parameters/RequestIDHeader"
          },
          {
            "$ref": "#/components/parameters/UserIDHeader"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKeyHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlagRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "503": {
            "$ref": "#/components/responses/Error"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "AuthorizationHeader": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "RequestIDHeader": {
        "name": "X-Request-Id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "UserIDHeader": {
        "name": "X-User-Id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "IdempotencyKeyHeader": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "ApproveRequest": {
        "type": "object",
        "required": [
          "submission_id",
          "campaign_id"
        ],
        "properties": {
          "submission_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "RejectRequest": {
        "type": "object",
        "required": [
          "submission_id",
          "campaign_id",
          "rejection_reason"
        ],
        "properties": {
          "submission_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "rejection_reason": {
            "type": "string"
          },
          "rejection_notes": {
            "type": "string"
          }
        }
      },
      "FlagRequest": {
        "type": "object",
        "required": [
          "submission_id",
          "campaign_id",
          "flag_reason"
        ],
        "properties": {
          "submission_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "flag_reason": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "DecisionResponse": {
        "type": "object",
        "required": [
          "status",
          "data",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "data": {
            "type": "object",
            "required": [
              "decision_id",
              "submission_id",
              "campaign_id",
              "moderator_id",
              "action",
              "reason",
              "queue_status",
              "created_at"
            ],
            "properties": {
              "decision_id": {
                "type": "string"
              },
              "submission_id": {
                "type": "string"
              },
              "campaign_id": {
                "type": "string"
              },
              "moderator_id": {
                "type": "string"
              },
              "action": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "queue_status": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "QueueResponse": {
        "type": "object",
        "required": [
          "status",
          "data",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "data": {
            "type": "object",
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "submission_id",
                    "campaign_id",
                    "creator_id",
                    "status",
                    "risk_score",
                    "report_count",
                    "queued_at"
                  ],
                  "properties": {
                    "submission_id": {
                      "type": "string"
                    },
                    "campaign_id": {
                      "type": "string"
                    },
                    "creator_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "risk_score": {
                      "type": "number"
                    },
                    "report_count": {
                      "type": "integer"
                    },
                    "queued_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "assigned_moderator_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": [
          "status",
          "error",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
